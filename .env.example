# Configurações do Servidor
PORT=5000
NODE_ENV=development

# Configurações do Banco de Dados (PostgreSQL na VPS ou Local)
DB_HOST=localhost
DB_PORT=5432
DB_USER=seu_usuario
DB_PASSWORD=sua_senha
DB_DATABASE=seu_banco_crm
DB_SSL=false

# Configurações de Integração n8n / Evolution API
# Webhook do n8n para onde o CRM envia requisições de resposta da IA
N8N_WEBHOOK_URL=https://n8n.suavps.com/webhook/whatsapp-webhook

# URL e chave da Evolution API (usada pelo n8n para responder no WhatsApp)
EVOLUTION_API_URL=https://evolution.seuservidor.com/message/sendText/instancia
EVOLUTION_API_KEY=sua_chave_evolution_api

# URL do CRM para o n8n chamar (webhook-ingest)
CRM_WEBHOOK_URL=http://localhost:5000/api/leads/webhook-ingest
